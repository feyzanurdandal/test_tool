      "id": "3699ecb6-d925-45a9-9c7d-c4479d40fc02",
      "name": "HTTP Request3"
    },
    {
      "parameters": {
        "jsCode": "// 🦾 Feyza'nın Tuvaline Özel (Form5, Form12, Form13) Uyumlu Hafıza İşleyici\nconst parsedSteps = [];\nlet scenarioName = \"isimsiz-senaryo\";\nlet targetUrl = \"\";\n\n// 1. En baştaki Form Trigger'dan ana bilgileri çekiyoruz\ntry {\n    const triggerData = $node[\"Form Trigger\"].json; \n    scenarioName = triggerData.scenarioName || scenarioName;\n    targetUrl = triggerData.targetUrl || targetUrl;\n} catch (e) {\n    console.log(\"Trigger okunamadı.\");\n}\n\n// 2. Hafızadaki formları isimlerine göre milimetrik tarayan fonksiyon\nfunction extractStepsFromForm(nodeName) {\n    try {\n        const formData = $node[nodeName].json;\n        if (!formData) return;\n\n        // Form alanlarını (1'den 50'ye kadar) tarıyoruz kanka\n        for (let i = 1; i <= 50; i++) {\n            const typeKey = `step${i}_type`;\n            const instrKey = `step${i}_instruction`;\n            const fieldKey = `step${i}_variable`;\n\n            // Eğer formun içindeki instruction (emir) alanı doldurulmuşsa içeri al kanka\n            if (formData[instrKey] && formData[instrKey].trim() !== \"\") {\n                const stepObject = {\n                    type: formData[typeKey] || \"act\",\n                    instruction: formData[instrKey].trim()\n                };\n\n                // Eğer extract adımıysa ve field girilmişse ekle\n                if (formData[fieldKey] && formData[fieldKey].trim() !== \"\") {\n                    stepObject.field = formData[fieldKey].trim();\n                }\n\n                parsedSteps.push(stepObject);\n            }\n        }\n    } catch (err) {\n        // Kullanıcı o form sayfasına hiç uğramadıysa (IF'ten saptıysa) hatayı yutuyoruz kanka\n    }\n}\n\n// 🚨 SENİN TUVALİNDEKİ GERÇEK İSİMLERLE EŞLEŞTİRME NOKTASI:\nextractStepsFromForm(\"Form 1\");  // İlk form sayfan\nextractStepsFromForm(\"Form 2\"); // İkinci form sayfan\nextractStepsFromForm(\"Form 3\"); // Üçüncü form sayfan\n\n// 3. Stagehand motorunun beklediği o pürüzsüz orijinal çıktı paketi\nreturn [{\n    json: {\n        scenarioName: scenarioName,\n        targetUrl: targetUrl,\n        steps: parsedSteps\n    }\n}];"
      },
